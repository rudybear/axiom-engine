@module perf_collision;
@intent("Performance test: 10000 sphere-sphere collision checks in < 100ms");
@constraint { optimize_for: "performance" };

@pure @inline(always)
fn check_collision(x1: f64, y1: f64, z1: f64, r1: f64,
                   x2: f64, y2: f64, z2: f64, r2: f64) -> i32 {
    let dx: f64 = x2 - x1;
    let dy: f64 = y2 - y1;
    let dz: f64 = z2 - z1;
    let dist_sq: f64 = dx * dx + dy * dy + dz * dz;
    let radii_sum: f64 = r1 + r2;
    if dist_sq < radii_sum * radii_sum { return 1; }
    return 0;
}

fn main() -> i32 {
    let n: i32 = 1000;
    let hits: i32 = 0;

    // O(n^2) collision test — 1M checks
    let seed: i64 = 42;
    for i: i32 in range(0, n) {
        let x1: f64 = to_f64(i) * 0.01;
        let y1: f64 = to_f64(i) * 0.007;
        let z1: f64 = to_f64(i) * 0.013;
        for j: i32 in range(0, n) {
            let x2: f64 = to_f64(j) * 0.01;
            let y2: f64 = to_f64(j) * 0.007;
            let z2: f64 = to_f64(j) * 0.013;
            hits = hits + check_collision(x1, y1, z1, 0.1, x2, y2, z2, 0.1);
        }
    }

    print_i32(hits);
    return 0;
}
